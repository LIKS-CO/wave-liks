<?xml version="1.0" encoding="utf-8"?><!--
   Data extraction rules for Android 12+ (API 31+). The encrypted API key file
   (liks_sports_secure.xml) is excluded from both cloud backup and device
   transfer. The on-device Gemma model file (~2.58 GB) is also excluded from
   both to avoid transferring a huge file; it is re-downloaded on restore.
   See https://developer.android.com/about/versions/12/backup-restore
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="liks_sports_secure.xml"/>
        <exclude domain="file" path="gemma-4-E2B-it.litertlm"/>
        <exclude domain="file" path="gemma-4-E2B-it.litertlm.tmp"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="liks_sports_secure.xml"/>
        <exclude domain="file" path="gemma-4-E2B-it.litertlm"/>
        <exclude domain="file" path="gemma-4-E2B-it.litertlm.tmp"/>
    </device-transfer>
</data-extraction-rules>
